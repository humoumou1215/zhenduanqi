[
  {
    "name": "dashboard",
    "description": "当前系统的实时数据面板",
    "category": "jvm",
    "riskLevel": "low",
    "params": [
      {
        "name": "-i",
        "description": "刷新间隔（毫秒）",
        "required": false,
        "example": "dashboard -i 1000"
      },
      {
        "name": "-n",
        "description": "刷新次数",
        "required": false,
        "example": "dashboard -n 3"
      }
    ],
    "examples": [
      {
        "command": "dashboard",
        "description": "显示实时数据面板，默认5秒刷新一次"
      },
      {
        "command": "dashboard -i 1000",
        "description": "1秒刷新一次"
      },
      {
        "command": "dashboard -n 5",
        "description": "刷新5次后退出"
      }
    ],
    "notes": "建议使用 -n 参数来控制刷新次数"
  },
  {
